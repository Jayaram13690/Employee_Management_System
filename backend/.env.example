# ===== MySQL Database Configuration =====
# Change these values to match your MySQL setup
DB_URL=jdbc:mysql://localhost:3306/emp_management?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ===== Server Configuration =====
SERVER_PORT=8080

# ===== JWT Configuration =====
# Generate a secure key: https://generate-random.org/
# Encode to Base64: https://www.base64encode.org/
# Or use: echo -n "YourSecureKeyHere" | base64
JWT_SECRET=your_secret_code
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ===== File Upload Configuration =====
UPLOAD_DIR=./uploads/photos

# ===== Email Configuration (Optional) =====
# For Gmail:
# 1. Enable 2FA on your Google account
# 2. Generate App Password: https://support.google.com/accounts/answer/185833
# 3. Use the generated password below (not your regular password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@emp-management.com
